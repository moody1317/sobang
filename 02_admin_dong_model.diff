+# app/models/admin_dong.py
+from sqlalchemy import Column, Integer, String, ForeignKey, JSON, Numeric
+from app.core.database import Base
+
+
+class AdminDong(Base):
+    __tablename__ = "admin_dongs"
+
+    id = Column(Integer, primary_key=True)
+    admin_code = Column(String(20), unique=True, nullable=False)   # 행정동코드 — KIKcd_H/admmCd/adm_cd2 공통 코드
+    dong_name = Column(String(50), nullable=False)
+    sigungu_nm = Column(String(50))
+    sido_nm = Column(String(50))
+
+    geometry = Column(JSON, nullable=True)   # GeoJSON 미매칭 동은 NULL로 남김
+
+    safety_center_id = Column(Integer, ForeignKey("safety_centers_v2.id"), nullable=True)
+    risk_score = Column(Numeric(5, 2), nullable=True)
